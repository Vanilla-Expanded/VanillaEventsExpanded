<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- ========== Condition events ========== -->
	<IncidentDef>
		<defName>VEE_Drought</defName>
		<label>drought</label>
		<category>Misc</category>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<workerClass>IncidentWorker_MakeGameCondition</workerClass>
		<gameCondition>VEE_Drought</gameCondition>
		<letterLabel>Drought</letterLabel>
		<letterText>An extreme drought has set over the area. Rain clouds have vanished, and the sun is baking the earth.\n\nOutdoor crops and wild plants will suffer heavily from the lack of moisture, almost halting their growth and eventually dying off. The fires will spread much quicker.\n\nPlants sown in hydroponics systems are not affected.</letterText>
		<letterDef>ThreatSmall</letterDef>
		<requireColonistsPresent>true</requireColonistsPresent>
		<baseChance>0.12</baseChance>
		<minRefireDays>90</minRefireDays>
		<earliestDay>60</earliestDay>
		<minGreatestPopulation>0</minGreatestPopulation>
		<durationDays>
			<min>4.5</min>
			<max>12.5</max>
		</durationDays>
		<disallowedBiomes>
			<li>IceSheet</li>
			<li>SeaIce</li>
			<li>ExtremeDesert</li>
			<li MayRequire="Ludeon.RimWorld.Odyssey">Grasslands</li>
			<li MayRequire="sarg.alphabiomes">AB_RockyCrags</li>
			<li MayRequire="sarg.alphabiomes">AB_IdyllicMeadows</li>
			<li MayRequire="sarg.alphabiomes">AB_PropaneLakes</li>
			<li MayRequire="sarg.alphabiomes">AB_MechanoidIntrusion</li>
		</disallowedBiomes>
		<disabledWhen>
			<extremeWeatherIncidentsDisabled>true</extremeWeatherIncidentsDisabled>
		</disabledWhen>
	</IncidentDef>
