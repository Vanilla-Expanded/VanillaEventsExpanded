	<ThingDef ParentName="BuildingBase" Name="VEE_ShipChunkHumanBase">
		<defName>VEE_ShipChunkHuman</defName>
		<graphicData>
			<texPath>Things/Buildings_Exotic/CrashedShipChunk_Normal</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<drawSize>(2,2)</drawSize>
			<damageData>
				<rect>(0.1,0.1,1.8,1.8)</rect>
			</damageData>
			<shadowData>
				<volume>(1.39,0.5,1.25)</volume>
			</shadowData>
		</graphicData>
		<label>orbital ship chunk</label>
		<description>A large chunk of an orbital ship, violently torn off during a catastrophic structural failure in high orbit. Having crashlanded not long ago, it still contains useful resources which you can acquire by deconstructing it.</description>
		<category>Building</category>
		<altitudeLayer>Building</altitudeLayer>
		<pathCost>35</pathCost>
		<blockWind>true</blockWind>
		<passability>PassThroughOnly</passability>
		<fillPercent>0.50</fillPercent>
		<size>(2,2)</size>
		<statBases>
			<MaxHitPoints>300</MaxHitPoints>
			<Flammability>0</Flammability>
			<Beauty>-20</Beauty>
			<WorkToBuild>12000</WorkToBuild>
		</statBases>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<killedLeavings>
			<ChunkSlagSteel>2</ChunkSlagSteel>
		</killedLeavings>
		<costList>
			<ComponentIndustrial>3</ComponentIndustrial>
			<Steel>20</Steel>
		</costList>
		<building>
			<claimable>false</claimable>
			<alwaysDeconstructible>true</alwaysDeconstructible>
		</building>
		<selectable>true</selectable>
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		<drawerType>MapMeshOnly</drawerType>
		<repairEffect>ConstructMetal</repairEffect>
