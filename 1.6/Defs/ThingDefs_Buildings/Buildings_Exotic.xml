	<ThingDef ParentName="SkyfallerBase">
		<defName>SlagIncoming</defName> <!--This one is now unused, keeping it for compat -->
		<label>slag (incoming)</label>
		<size>(1, 1)</size>
		<skyfaller>
			<shadowSize>(1.5, 1.5)</shadowSize>
			<explosionRadius>3</explosionRadius>
