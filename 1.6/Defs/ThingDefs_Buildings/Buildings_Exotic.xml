<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- ========== Crashed shuttles ========== -->
	<ThingDef ParentName="BuildingBase" Name="VEE_ShuttleBase">
		<defName>VEE_Shuttle</defName>
		<thingClass>VEE.Shuttle</thingClass>
		<tickerType>Normal</tickerType>
		<graphicData>
			<texPath>Things/Buildings_Exotic/Shuttle_Crashed/Shuttle_Standard_Crashed</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(5,3)</drawSize>
			<damageData>
				<rect>(0.1,0.1,1.8,1.8)</rect>
			</damageData>
			<shadowData>
				<volume>(1.39,0.5,1.25)</volume>
			</shadowData>
		</graphicData>
		<label>crashed shuttle</label>
		<description>A crashed, spacer-tech shuttle designed for transit between surface and orbit. Can be deconstructed to yield some valuable salvage.</description>
		<category>Building</category>
		<altitudeLayer>Building</altitudeLayer>
		<pathCost>50</pathCost>
		<blockWind>true</blockWind>
		<passability>PassThroughOnly</passability>
		<fillPercent>0.75</fillPercent>
		<size>(5,3)</size>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<Flammability>0</Flammability>
			<Beauty>-20</Beauty>
			<WorkToBuild>1440</WorkToBuild>
		</statBases>
		<killedLeavings>
			<Plasteel>25</Plasteel>
			<ComponentIndustrial>3</ComponentIndustrial>
			<Steel>14</Steel>
			<ShuttleEngine MayRequire="Ludeon.RimWorld.Odyssey">1</ShuttleEngine>
			<ChunkSlagSteel>1</ChunkSlagSteel>
		</killedLeavings>
		<costList>
			<Plasteel>35</Plasteel>
			<ComponentIndustrial>6</ComponentIndustrial>
			<Steel>20</Steel>
			<ShuttleEngine MayRequire="Ludeon.RimWorld.Odyssey">1</ShuttleEngine>
		</costList>
		<building>
			<claimable>false</claimable>
			<alwaysDeconstructible>true</alwaysDeconstructible>
		</building>
		<selectable>true</selectable>
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		<drawerType>MapMeshOnly</drawerType>
		<repairEffect>ConstructMetal</repairEffect>
	</ThingDef>
	<ThingDef ParentName="SkyfallerBase" Name="VEE_ShuttleIncomingBase">
		<defName>ShuttleChunkIncoming</defName>
		<label>crashed shuttle (incoming)</label>
		<size>(5, 3)</size>
		<thingClass>VEE.IncomingSmoker</thingClass>
		<graphicData>
			<texPath>Skyfallers/Shuttle_Standard_Skyfaller</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(5,3)</drawSize>
			<damageData>
				<rect>(0.1,0.1,1.8,1.8)</rect>
			</damageData>
			<shadowData>
				<volume>(1.39,0.5,1.25)</volume>
			</shadowData>
		</graphicData>
		<skyfaller>
			<movementType>Decelerate</movementType>
			<shadow>Things/Skyfaller/SkyfallerShadowRectangle</shadow>
			<shadowSize>(5.5,3.5)</shadowSize>
			<motesPerCell>1</motesPerCell>
			<anticipationSound>VEE_Ship_CrashLanding</anticipationSound>
			<anticipationSoundTicks>250</anticipationSoundTicks>
			<ticksToImpactRange>380~550</ticksToImpactRange>
			<angleCurve>
				<points>
					<li>(0,-60)</li>
					<li>(1,-90)</li>
				</points>
			</angleCurve>
			<rotationCurve>
				<points>
					<li>(0,30)</li>
					<li>(0.5,5)</li>
					<li>(0.9,-5)</li>
					<li>(0.95,0)</li>
				</points>
			</rotationCurve>
			<zPositionCurve>
				<points>
					<li>(0.95,0.75)</li>
					<li>(1,0)</li>
				</points>
			</zPositionCurve>
			<speedCurve>
				<points>
					<li>(0.6,0.6)</li>
					<li>(0.95,0.55)</li>
				</points>
			</speedCurve>
			<explosionDamage>Flame</explosionDamage>
			<explosionRadius>6.9</explosionRadius>
			<cameraShake>1</cameraShake>
		</skyfaller>
	</ThingDef>
	<ThingDef ParentName="VEE_ShuttleBase">
		<defName>VEE_Shuttle_Combat</defName>
		<graphicData>
			<texPath>Things/Buildings_Exotic/Shuttle_Crashed/Shuttle_Combat_Crashed</texPath>
